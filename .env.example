# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/woundcare_db

# --- Django Security ---
DJANGO_SECRET_KEY=django-insecure-replace-this-with-a-proper-key-for-production
DEBUG=True

# --- AI Configuration (Ollama) ---
# For local and server (VPS):
OLLAMA_BASE_URL=http://localhost:11434

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="Surgical Wound Care"
SMTP_FROM_EMAIL=no-reply@woundcare.com

# --- Other ---
MAX_FILE_SIZE=10485760
